{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"sourceMap": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"paths": {
			"@/*": ["./src/*"]
		},
		"types": ["chrome"]
	},

	"include": ["src/**/*.ts", "src/**/*.vue", "src/providers/providers/*.ts"],

	"exclude": ["node_modules", "**/*.test.ts"]
}
