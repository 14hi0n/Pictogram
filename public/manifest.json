{
    "manifest_version": 3,
    "name": "Pictogram",
    "version": "1.0.2",
    "version_name": "1.0.2-alpha",
    "description": "тест. только danbooru и pixiv",
    "homepage_url": "https://github.com/14hi0n/Pictogram",
    "options_page": "option.html",
    "icons": {
        "16": "icons/icon_16.png",
        "32": "icons/icon_32.png",
        "48": "icons/icon_48.png",
        "128": "icons/icon_128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Pictogram"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "permissions": [
        "storage",
        "tabs",
        "sidePanel",
        "declarativeNetRequest"
    ],
    "host_permissions": [
        "*://cdn.donmai.us/*",
        "*://i.pximg.net/*",
        "*://static.zerochan.net/*"
    ],
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "danbooru_cdn_rules",
                "enabled": true,
                "path": "rules/danbooru_cdn_rules.json"
            },
            {
                "id": "pixiv_cdn_rules",
                "enabled": true,
                "path": "rules/pixiv_cdn_rules.json"
            },
            {
                "id": "zerochan_cdn_rules",
                "enabled": true,
                "path": "rules/zerochan_cdn_rules.json"
            }
        ]
    },
    "web_accessible_resources": [
        {
            "resources": [
                "contentScript.css"
            ],
            "matches": [
                "*://danbooru.donmai.us/*",
                "*://www.pixiv.net/*",
                "*://www.zerochan.net/*"
            ]
        }
    ],
    "content_scripts": [
        {
            "matches": [
                "*://danbooru.donmai.us/posts/*",
                "*://www.pixiv.net/*",
                "*://www.zerochan.net/*"
            ],
            "run_at": "document_idle",
            "js": [
                "contentScript.js"
            ]
        }
    ]
}