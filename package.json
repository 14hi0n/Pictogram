{
    "name": "pictogram-extension",
    "version": "1.3.0",
    "license": "AGPL-3.0-or-later",
    "description": "A simple and efficient Chrome browser extension that streamlines the process of sending art to your Telegram channel through a Telegram bot. Quickly forward art from various sources directly to your Telegram channel with just one click.",
    "private": true,
    "scripts": {
        "watch": "webpack --mode=development --watch --config config/webpack.config.js",
        "build": "webpack --mode=production --config config/webpack.config.js",
        "serve": "webpack serve --mode=development --config config/webpack.config.js",
        "pack": "node pack.js",
        "repack": "npm run build && npm run pack",
        "serve-release": "npm run repack && npx --yes serve release -p 8765",
        "typecheck": "tsc --project tsconfig.check.json",
        "format": "prettier --write --ignore-unknown \"{config,public,src}/**/*.{html,css,js,ts,json}\"",
        "test": "jest"
    },
    "devDependencies": {
        "@babel/core": "^7.22.1",
        "@babel/plugin-syntax-dynamic-import": "^7.8.3",
        "@babel/preset-env": "^7.22.2",
        "@types/chrome": "^0.0.261",
        "@types/jest": "^29.5.12",
        "adm-zip": "^0.5.10",
        "babel-jest": "^29.5.0",
        "copy-webpack-plugin": "^10.2.4",
        "css-loader": "^6.7.3",
        "file-loader": "^6.2.0",
        "jest": "^29.5.0",
        "jest-environment-jsdom": "^30.4.1",
        "jsdom": "^22.1.0",
        "mini-css-extract-plugin": "^2.7.5",
        "prettier": "^2.8.8",
        "sass": "^1.62.1",
        "sass-loader": "^13.2.2",
        "style-loader": "^3.3.2",
        "ts-jest": "^29.1.2",
        "ts-loader": "^9.5.1",
        "typescript": "^5.7.2",
        "vue-loader": "^17.4.2",
        "vue-style-loader": "^4.1.3",
        "webpack": "^5.81.0",
        "webpack-cli": "^4.10.0",
        "webpack-dev-server": "^4.15.0",
        "webpack-merge": "^5.8.0"
    },
    "dependencies": {
        "vue": "^3.5.13"
    }
}